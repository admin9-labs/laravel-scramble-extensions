{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "admin9/laravel-scramble-extensions",
    "description": "Scramble extensions for Laravel business-response APIs — auto-wraps OpenAPI docs with success/error envelope, scene-based form request extraction, and filter query parameter extraction.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "scramble", "openapi", "swagger"],
    "authors": [
        {
            "name": "fengqiyue",
            "email": "fengqiyue@gmail.com"
        }
    ],
    "homepage": "https://github.com/admin9-labs/laravel-scramble-extensions",
    "support": {
        "issues": "https://github.com/admin9-labs/laravel-scramble-extensions/issues",
        "source": "https://github.com/admin9-labs/laravel-scramble-extensions"
    },
    "require": {
        "php": "^8.3",
        "dedoc/scramble": "^0.13.30",
        "nikic/php-parser": "^4.0 || ^5.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^11.5 || ^12.5"
    },
    "suggest": {
        "mitoop/laravel-api-response": "Required for business response envelope wrapping (^7.0)",
        "mitoop/laravel-efficient-form-request": "Required for scene-based form request parameter extraction",
        "mitoop/laravel-query-builder": "Required for filter query parameter extraction"
    },
    "autoload": {
        "psr-4": {
            "Admin9\\ScrambleExtensions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Admin9\\ScrambleExtensions\\Tests\\": "tests/",
            "Mitoop\\Http\\": "tests/Fixtures/Mitoop/Http/",
            "Mitoop\\LaravelEfficientFormRequest\\": "tests/Fixtures/Mitoop/LaravelEfficientFormRequest/",
            "Mitoop\\LaravelQueryBuilder\\": "tests/Fixtures/Mitoop/LaravelQueryBuilder/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "format:test": "pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Admin9\\ScrambleExtensions\\ScrambleExtensionsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
